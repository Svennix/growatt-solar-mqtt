# ============================================
# IOT PROJECTS - SECURITY & BUILD FILES
# ============================================

# CRITICAL: Configuration files with credentials
**/config.h
**/secrets.h
**/credentials.h
**/private.h
**/.env
**/.env.*
!**/.env.example

# PlatformIO build files
.pio/
.vscode/
.pioenvs/
.piolibdeps/
.clang_complete
.gcc-flags.json
lib/

# Arduino IDE
*.ino.bin
*.ino.elf
*.ino.map

# Python bytecode (if using scripts)
__pycache__/
*.py[cod]
*.pyo

# OS files
.DS_Store
Thumbs.db
*.swp
*.swo
*~
.idea/
*.iml

# Backup files
*.bak
*.backup
*_backup
*.old

# Logs
*.log
logs/

# Compiled binaries
*.bin
*.hex
*.elf
*.out
*.o
*.a

# Documentation that might contain secrets
**/CREDENTIALS.txt
**/PASSWORDS.txt
**/SECRET*.txt
**/API_KEYS.txt

# Temporary files
*.tmp
*.temp
.cache/

# Certificate and key files
*.pem
*.key
*.crt
*.cer
*.p12
*.pfx

# Database files (if any)
*.db
*.sqlite
*.sqlite3

# Node modules (if using Node.js tools)
node_modules/

# IDE specific
.vscode/settings.json
.vscode/launch.json
